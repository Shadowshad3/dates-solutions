<article{{ attributes.addClass('service-node-page') }}>
  {{ title_prefix }}
  {{ title_suffix }}

  <section class="service-node-hero relative overflow-hidden bg-slate-950 text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(37,99,235,0.18),transparent_26%),radial-gradient(circle_at_right,rgba(34,211,238,0.10),transparent_24%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:36px_36px] opacity-30"></div>

    <div class="container-site relative z-10 py-16 lg:py-20">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_.95fr] lg:items-center">
        <div class="max-w-3xl">
          <div class="inline-flex rounded-full border border-cyan-400/20 bg-white/[0.05] px-4 py-2 text-sm font-medium text-cyan-200 shadow-sm backdrop-blur-sm">
            Core service
          </div>

          <h1 class="mt-6 text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-6xl">
            {{ label }}
          </h1>

          {% if service_summary %}
            <div class="service-node-hero-summary mt-6 max-w-lg text-base leading-7 text-slate-300">
              {{ service_summary|raw }}
            </div>
          {% endif %}

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="{{ service_consultation_url }}" class="button-primary">Book consultation</a>
            <a href="{{ service_contact_url }}" class="inline-flex items-center justify-center rounded-full border border-white/18 bg-white/[0.04] px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/[0.08]">
              Contact us
            </a>
          </div>

          <div class="mt-10 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-4 text-sm font-medium text-slate-200">Structured delivery</div>
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-4 text-sm font-medium text-slate-200">Business-aligned execution</div>
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-4 text-sm font-medium text-slate-200">Long-term support</div>
          </div>
        </div>

        <div>
          <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.04] shadow-2xl shadow-slate-950/30 backdrop-blur-sm">
            {% if service_image.url %}
              <img
                src="{{ service_image.url }}"
                alt="{{ service_image.alt ?: label }}"
                class="block aspect-[16/10] w-full object-cover"
              >
            {% else %}
              <div class="aspect-[16/10] w-full bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.16),transparent_24%),linear-gradient(135deg,#0f172a_0%,#111827_45%,#1e3a8a_100%)]"></div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-site py-14 lg:py-18">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,0.68fr)_minmax(280px,0.32fr)] lg:gap-12">
        <div class="min-w-0">
          <div class="service-proof-line">
            <div>Built for scalability</div>
            <div>Designed for long-term use</div>
            <div>Structured for business workflows</div>
          </div>

          {% if content.field_ds_service_content %}
            <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-8 lg:p-10">
              <div class="service-rich-text">
                <div class="service-block">
                  {{ content.field_ds_service_content }}
                </div>
              </div>
            </div>
          {% endif %}
        </div>

        <aside class="min-w-0">
          <div class="sticky top-28 space-y-5">
            <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 shadow-sm">
              <div class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">Why Date Solutions</div>
              <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">
                Practical delivery with long-term ownership
              </h2>
              <div class="mt-4 text-sm leading-7 text-slate-600">
                We build around real workflows, clear scope, maintainable structure, and support after launch.
              </div>

              <div class="mt-6 grid gap-3">
                <div class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700">Clear implementation approach</div>
                <div class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700">Modern scalable architecture</div>
                <div class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700">Support beyond go-live</div>
              </div>
            </div>

            <div class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm">
              <div class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">Next step</div>
              <h3 class="mt-3 text-xl font-semibold text-slate-950">
                Let’s talk about your requirements
              </h3>
              <div class="mt-3 text-sm leading-7 text-slate-600">
                Whether you need a website, integration, optimization, or ongoing technical support, we can map the right approach.
              </div>

              <div class="mt-6 flex flex-col gap-3">
                <a href="{{ service_consultation_url }}" class="button-primary w-full">Book consultation</a>
                <a href="{{ service_contact_url }}" class="button-secondary w-full">Send inquiry</a>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</article>