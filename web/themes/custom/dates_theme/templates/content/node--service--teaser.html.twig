<article{{ attributes.addClass('rounded-[1.75rem]', 'border', 'border-slate-200', 'bg-white', 'p-6', 'shadow-sm', 'transition', 'duration-200', 'hover:-translate-y-1', 'hover:border-blue-300', 'hover:shadow-lg') }}>
  {% if content.field_ds_icon %}
    <div class="mb-4">
      {{ content.field_ds_icon }}
    </div>
  {% endif %}

  <div class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">
    Service
  </div>

  <h3 class="mt-4 text-xl font-semibold text-slate-900">
    <a href="{{ service_link }}" rel="bookmark" class="hover:text-blue-700">
      {{ label }}
    </a>
  </h3>

  {% if service_summary %}
    <div class="mt-3 text-sm leading-7 text-slate-600">
      {{ service_summary|raw }}
    </div>
  {% endif %}

  <div class="mt-5 text-sm font-medium text-slate-900">
    <a href="{{ service_link }}">Learn more →</a>
  </div>
</article>