{% import _self as menus %}

{% if items %}
  <nav class="header-nav" aria-label="{{ 'Main navigation'|t }}">
    <div class="header-nav__desktop">
      {{ menus.menu_links(items, attributes, 0, 'desktop') }}
    </div>

    <details class="header-nav__mobile">
      <summary class="header-nav__toggle">
        <span>Menu</span>
        <svg class="header-nav__icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 6H16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M4 10H16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M4 14H16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </summary>

      <div class="header-nav__drawer">
        {{ menus.menu_links(items, attributes, 0, 'mobile') }}
      </div>
    </details>
  </nav>
{% endif %}

{% macro menu_links(items, attributes, menu_level, variant) %}
  {% import _self as menus %}

  {% if items %}
    {% if menu_level == 0 and variant == 'desktop' %}
      <ul class="header-main-menu">
    {% elseif menu_level == 0 and variant == 'mobile' %}
      <ul class="header-mobile-menu">
    {% else %}
      <ul class="mt-3 space-y-2 rounded-xl border border-slate-200 bg-white p-4 shadow-lg">
    {% endif %}

    {% for item in items %}
      {% set item_classes = [
        'menu-item',
        item.is_expanded ? 'menu-item--expanded',
        item.is_collapsed ? 'menu-item--collapsed',
        item.in_active_trail ? 'menu-item--active-trail'
      ] %}

      <li{{ item.attributes.addClass(item_classes) }}>
        {% if menu_level == 0 and variant == 'desktop' %}
          <a
            href="{{ item.url }}"
            class="header-main-menu__link {% if item.in_active_trail %}is-active{% endif %}"
          >
            {{ item.title }}
          </a>
        {% elseif menu_level == 0 and variant == 'mobile' %}
          <a
            href="{{ item.url }}"
            class="header-mobile-menu__link {% if item.in_active_trail %}is-active{% endif %}"
          >
            {{ item.title }}
          </a>
        {% else %}
          <a
            href="{{ item.url }}"
            class="block text-sm font-medium text-slate-600 transition hover:text-brand-600"
          >
            {{ item.title }}
          </a>
        {% endif %}

        {% if item.below %}
          {{ menus.menu_links(item.below, attributes, menu_level + 1, variant) }}
        {% endif %}
      </li>
    {% endfor %}

    </ul>
  {% endif %}
{% endmacro %}