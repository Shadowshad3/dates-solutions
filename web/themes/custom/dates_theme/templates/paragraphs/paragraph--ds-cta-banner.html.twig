<section{{ attributes.addClass('w-full', 'bg-white') }}>
  {% if is_about_page %}
    <div class="container-site py-18 lg:py-22">
      <div class="relative overflow-hidden rounded-[2.5rem] border border-slate-200 bg-gradient-to-br from-slate-950 via-slate-900 to-[#13284b] px-8 py-10 text-white shadow-2xl shadow-slate-950/20 sm:px-10 lg:px-12 lg:py-12">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.18),transparent_24%),radial-gradient(circle_at_bottom_left,rgba(34,211,238,0.10),transparent_26%)]"></div>

        <div class="relative z-10 grid gap-10 lg:grid-cols-[1.08fr_.92fr] lg:items-end">
          <div class="max-w-2xl">
            {% if paragraph.field_ds_eyebrow.value %}
              <div class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-300">
                {{ paragraph.field_ds_eyebrow.value }}
              </div>
            {% endif %}

            <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
              {{ paragraph.field_ds_heading.value }}
            </h2>

            <div class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
              {{ content.field_ds_body }}
            </div>
          </div>

          <div class="lg:justify-self-end">
            <div class="rounded-[1.75rem] border border-white/10 bg-white/[0.05] p-5 backdrop-blur-sm">
              <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
                <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm font-medium text-slate-200">Strategy</div>
                <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm font-medium text-slate-200">Build</div>
                <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm font-medium text-slate-200">Support</div>
              </div>

              <div class="mt-5 flex flex-wrap gap-3">
                {% if primary_cta %}
                  <a href="{{ primary_cta.url }}" class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 shadow-sm transition hover:bg-slate-100">
                    {{ primary_cta.title }}
                  </a>
                {% endif %}

                {% if secondary_cta %}
                  <a href="{{ secondary_cta.url }}" class="inline-flex items-center justify-center rounded-full border border-white/18 bg-white/[0.04] px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/[0.08]">
                    {{ secondary_cta.title }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  {% elseif is_services_page %}
    <div class="container-site py-18 lg:py-20">
      <div class="services-cta-shell relative overflow-hidden rounded-[2.4rem] border border-slate-200 bg-gradient-to-r from-slate-950 via-slate-900 to-[#1c3157] px-8 py-10 text-white shadow-2xl shadow-slate-950/20 sm:px-10 lg:px-12 lg:py-12">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.18),transparent_22%),radial-gradient(circle_at_bottom_left,rgba(34,211,238,0.08),transparent_28%)]"></div>

        <div class="relative z-10 grid gap-10 lg:grid-cols-[1.06fr_.94fr] lg:items-center">
          <div class="max-w-3xl">
            {% if paragraph.field_ds_eyebrow.value %}
              <div class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-300">
                {{ paragraph.field_ds_eyebrow.value }}
              </div>
            {% endif %}

            <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
              {{ paragraph.field_ds_heading.value }}
            </h2>

            <div class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
              {{ content.field_ds_body }}
            </div>
          </div>

          <div class="lg:justify-self-end">
            <div class="rounded-[1.6rem] border border-white/10 bg-white/[0.05] p-5 backdrop-blur-sm">
              <div class="grid gap-3 sm:grid-cols-2">
                <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm font-medium text-slate-200">Project delivery</div>
                <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-3 text-sm font-medium text-slate-200">Long-term support</div>
              </div>

              <div class="mt-5 flex flex-wrap gap-3">
                {% if primary_cta %}
                  <a href="{{ primary_cta.url }}" class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 shadow-sm transition hover:bg-slate-100">
                    {{ primary_cta.title }}
                  </a>
                {% endif %}
                {% if secondary_cta %}
                  <a href="{{ secondary_cta.url }}" class="inline-flex items-center justify-center rounded-full border border-white/18 bg-white/[0.04] px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/[0.08]">
                    {{ secondary_cta.title }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  {% else %}
    <div class="container-site py-20">
      <div class="rounded-[2rem] bg-gradient-to-r from-slate-950 via-slate-900 to-slate-800 px-8 py-12 text-white shadow-2xl shadow-slate-300/30 sm:px-12">
        <div class="max-w-3xl">
          {% if paragraph.field_ds_eyebrow.value %}
            <div class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-300">
              {{ paragraph.field_ds_eyebrow.value }}
            </div>
          {% endif %}

          <h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">
            {{ paragraph.field_ds_heading.value }}
          </h2>

          <div class="mt-4 text-lg leading-8 text-slate-300">
            {{ content.field_ds_body }}
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            {% if primary_cta %}
              <a href="{{ primary_cta.url }}" class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950">
                {{ primary_cta.title }}
              </a>
            {% endif %}
            {% if secondary_cta %}
              <a href="{{ secondary_cta.url }}" class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3 text-sm font-semibold text-white">
                {{ secondary_cta.title }}
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</section>