{#
/**
 * @file
 * Theme override for the DS Form Section paragraph.
 */
#}

{% set eyebrow = content.field_ds_eyebrow %}
{% set heading = content.field_ds_heading %}
{% set body = content.field_ds_body %}

<section class="section-form-section">
  <div class="container-site">
    <div class="form-section__shell">
      <div class="form-section__intro">
        {% if eyebrow %}
          <div class="section-eyebrow">{{ eyebrow }}</div>
        {% endif %}

        {% if heading %}
          <h2 class="section-title">{{ heading }}</h2>
        {% endif %}

        {% if body %}
          <div class="section-copy">
            {{ body }}
          </div>
        {% endif %}

        <div class="form-trust-points">
          <div class="form-trust-point">Free initial consultation</div>
          <div class="form-trust-point">No commitment required</div>
          <div class="form-trust-point">Practical recommendations based on your setup</div>
          <div class="form-trust-point">Focused on long-term solutions, not quick fixes</div>
        </div>
      </div>

      <div class="form-section__panel">
        {{ ds_form }}
      </div>
    </div>
  </div>
</section>