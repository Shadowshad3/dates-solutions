<section{{ attributes.addClass('w-full', 'bg-slate-100') }}>
  <div class="container-site py-10">
    {% if paragraph.field_ds_heading.value %}
      <p class="text-center text-sm font-medium uppercase tracking-[0.24em] text-slate-500">
        {{ paragraph.field_ds_heading.value }}
      </p>
    {% endif %}

    {% if trust_items %}
      <div class="mt-6 grid grid-cols-2 gap-4 md:grid-cols-5">
        {% for item in trust_items %}
          <div class="rounded-2xl border border-slate-200 bg-white px-4 py-5 text-center text-sm font-medium text-slate-700 shadow-sm">
            {{ item }}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>