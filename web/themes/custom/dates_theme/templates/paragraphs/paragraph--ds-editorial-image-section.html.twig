{% set image_right = editorial_layout == 'image_right' %}

<section{{ attributes.addClass('w-full', is_about_page ? 'bg-white' : 'bg-slate-50') }}>
  <div class="container-site py-16 lg:py-22">
    <div class="grid gap-10 lg:items-center lg:gap-16 {{ image_right ? 'lg:grid-cols-[0.98fr_1.02fr]' : 'lg:grid-cols-[1.02fr_0.98fr]' }}">
      <div class="{{ image_right ? 'lg:order-2' : 'lg:order-1' }}">
        <div class="about-editorial-media overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-100 shadow-sm">
          {{ content.field_ds_image }}
        </div>
      </div>

      <div class="{{ image_right ? 'lg:order-1' : 'lg:order-2' }}">
        <div class="max-w-2xl">
          {% if paragraph.field_ds_eyebrow.value %}
            <div class="text-sm font-semibold uppercase tracking-[0.25em] text-blue-700">
              {{ paragraph.field_ds_eyebrow.value }}
            </div>
          {% endif %}

          <h2 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">
            {{ paragraph.field_ds_heading.value }}
          </h2>

          <div class="about-editorial-copy mt-6 text-lg leading-8 text-slate-600">
            {{ content.field_ds_body }}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>